# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# datasets & models
data/artists/**/raw/*
data/artists/**/processed/*
!data/artists/**/raw/.gitkeep
!data/artists/**/processed/.gitkeep
!data/artists/**/manifest.json
models/adapters/*.safetensors

# prototype uploads
/public/uploads/**/*.jpg
/public/uploads/**/*.jpeg
/public/uploads/**/*.png
/public/uploads/**/*.webp
!/public/uploads/**/.gitkeep

# python virtual environments
.venv/
venv/
__pycache__/
*.pyc

