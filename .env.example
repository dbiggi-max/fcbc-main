# ========================================================
# CREATOR STYLE LAB - ENVIRONMENT CONFIGURATION TEMPLATE
# ========================================================

# --------------------------------------------------------
# 1. DATABASE CONFIGURATION (PostgreSQL)
# --------------------------------------------------------
# Required for both Local Development and Production (Vercel / GCP).
# In production, use your fully qualified hosted PostgreSQL URL.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# --------------------------------------------------------
# 2. LOCAL AI & SIMULATED VALIDATION CONFIGURATION
# --------------------------------------------------------
# THEME_VALIDATOR_PROVIDER: "mock" (offline NLP), "python" (local PyTorch OpenCLIP), or "google_gemini" (Vertex AI)
THEME_VALIDATOR_PROVIDER="mock"
PYTHON_THEME_VALIDATOR_PATH="./ml/image_theme_validator/validate_image_theme.py"
PYTHON_THEME_VALIDATOR_TIMEOUT_MS="30000"

# --------------------------------------------------------
# 3. FUTURE PRODUCTION GOOGLE CLOUD PLATFORM CONFIGURATION
# --------------------------------------------------------
# Set these when deploying to GCP or enabling Vertex AI & GCS on Vercel.

# General GCP Identifiers
GOOGLE_CLOUD_PROJECT="your-gcp-project-id"

# Google Cloud Storage (GCS) for production image blobs (replaces local disk storage)
GCS_BUCKET_NAME="your-creator-style-lab-assets-bucket"

# Local GCP authorization (Local Dev only; do not set on Vercel or GCE where IAM roles are inherited)
GOOGLE_APPLICATION_CREDENTIALS="/absolute/path/to/your/service-account-key.json"

# --------------------------------------------------------
# 4. AUTH.JS / NEXTAUTH & GOOGLE OAUTH CONFIGURATION
# --------------------------------------------------------
# Auth.js / NextAuth
AUTH_SECRET=
AUTH_URL=http://localhost:3000

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Temporary MVP bootstrap only (Comma-separated emails to automatically promote to ADMIN)
ADMIN_BOOTSTRAP_EMAILS=

# --------------------------------------------------------
# 5. APP METADATA & OTHER CONTROLS
# --------------------------------------------------------
# Public app URL only if needed client-side
NEXT_PUBLIC_APP_URL="http://localhost:3000"
ADMIN_PASSCODE="admin123"
